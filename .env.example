# =============================================================================
# Nuit One — Environment Variables
# =============================================================================
# Copy to .env and fill in values for local development.

# --- Janua SSO ---
JANUA_URL=http://localhost:8000
JANUA_CLIENT_ID=nuit-one
JANUA_CLIENT_SECRET=
JANUA_REDIRECT_URI=http://localhost:5173/auth/callback

# --- PostgreSQL (Drizzle ORM) ---
DATABASE_URL=postgresql://nuitone:nuitone@localhost:5432/nuitone

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nuit-one-stems
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# --- Soketi (WebSocket server) ---
SOKETI_HOST=localhost
SOKETI_PORT=6001
SOKETI_APP_ID=nuit-one
SOKETI_APP_KEY=
SOKETI_APP_SECRET=

# --- App ---
PUBLIC_APP_URL=http://localhost:5173
SESSION_SECRET=change-me-in-production
PORT=3000
