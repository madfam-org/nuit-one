{
  "name": "nuit-one",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "pnpm --filter @nuit-one/db generate",
    "db:migrate": "pnpm --filter @nuit-one/db migrate",
    "db:push": "pnpm --filter @nuit-one/db push",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.39.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
